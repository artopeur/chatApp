<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SecondFragment">

    <!-- Header with Back Button, Room Name, and Username -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="9dp"
        android:background="#000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FAFFAF">

            <!-- Back Button -->
            <!--<Button
                android:id="@+id/backButton"
                android:layout_width="100dp"
                android:layout_height="48dp"
                android:text="back"
                android:textSize="20sp" />-->
        </LinearLayout>
        <!-- Room Name and Username -->
        <TextView
            android:id="@+id/roomNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Room: General"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff" />

        <TextView
            android:id="@+id/usernameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="User: John"
            android:textSize="12sp"
            android:textColor="#ffffff" />

        <!-- Message List -->
        <ListView
            android:id="@+id/messageList"
            android:layout_width="match_parent"
            android:layout_height="600dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toTopOf="@+id/messageInput"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/roomNameText"
            android:background="#00ff00"
            android:textColor="#000000"/>
        <Button
            android:id="@+id/sendButton"
            android:layout_width="80dp"
            android:layout_height="50dp"
            android:text="send"
            android:textSize="12sp" />
        <!-- Message Input -->
        <EditText
            android:id="@+id/messageInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textColor="#000000"
            android:textSize="14sp"
            android:background="#ffffff"
            android:textColorHint="#000000"
            android:hint="enter_message"
            android:inputType="text|textMultiLine"
            android:padding="12dp"
            android:layout_marginEnd="8dp" />

        <!-- Send Button -->


    </LinearLayout>
</androidx.core.widget.NestedScrollView>